-- Exe-5: Return Data from a Stored Procedure
-- Goal: Get total number of employees in a department

CREATE PROCEDURE sp_GetEmployeeCountByDepartment
    @DepartmentID INT
AS
BEGIN
    SELECT COUNT(*) AS TotalEmployees
    FROM Emp_Master
    WHERE DepartmentID = @DepartmentID;
END;
GO

-- Execute the stored procedure
EXEC sp_GetEmployeeCountByDepartment @DepartmentID = 3;
GO

-- Exe-6: Use Output Parameter in Stored Procedure
-- Goal: Get total salary of employees in a department using OUTPUT parameter

CREATE PROCEDURE sp_GetTotalSalaryByDepartment
    @DepartmentID INT,
    @TotalSalary DECIMAL(10,2) OUTPUT
AS
BEGIN
    SELECT @TotalSalary = SUM(Salary)
    FROM Emp_Master
    WHERE DepartmentID = @DepartmentID;
END;
GO

DECLARE @SalarySum DECIMAL(10,2);
EXEC sp_GetTotalSalaryByDepartment
    @DepartmentID = 3,
    @TotalSalary = @SalarySum OUTPUT;


SELECT @SalarySum AS TotalSalary;
GO
-- Exe-7: Stored Procedure with Multiple Parameters
-- Goal: Update employee salary

CREATE PROCEDURE sp_UpdateEmployeeSalary
    @EmployeeID INT,
    @NewSalary DECIMAL(10,2)
AS
BEGIN
    UPDATE Emp_Master
    SET Salary = @NewSalary
    WHERE EmployeeID = @EmployeeID;
END;
GO

