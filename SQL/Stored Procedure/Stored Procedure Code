-- Exe-8: Stored Procedure with Conditional Logic
-- Goal: Give bonus to employees based on Department

CREATE PROCEDURE sp_GiveBonus
    @DepartmentID INT,
    @BonusAmount DECIMAL(10,2)
AS
BEGIN
    UPDATE Emp_Master
    SET Salary = Salary + @BonusAmount
    WHERE DepartmentID = @DepartmentID;
END;
