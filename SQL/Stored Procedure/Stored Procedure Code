-- Exe-9: Stored Procedure with Transactions
-- Goal: Update employee salary with transaction safety

CREATE PROCEDURE sp_UpdateSalaryWithTransaction
    @EmployeeID INT,
    @NewSalary DECIMAL(10,2)
AS
BEGIN
    BEGIN TRY
        BEGIN TRANSACTION;

        
        UPDATE Emp_Master
        SET Salary = @NewSalary
        WHERE EmployeeID = @EmployeeID;

        COMMIT TRANSACTION;
    END TRY

    BEGIN CATCH
       
        ROLLBACK TRANSACTION;

        PRINT 'Error occurred. Transaction rolled back.';
    END CATCH
END;
GO

EXEC sp_UpdateSalaryWithTransaction 2, 6500.00;
GO

SELECT *
FROM Emp_Master
WHERE EmployeeID = 2;
GO

-- Exe-10: Stored Procedure using Dynamic SQL
-- Goal: Retrieve employee details using flexible filters

CREATE PROCEDURE sp_GetEmployeesDynamic
    @FilterColumn NVARCHAR(50),
    @FilterValue NVARCHAR(100)
AS
BEGIN
    DECLARE @SQL NVARCHAR(MAX);

    SET @SQL = '
        SELECT EmployeeID, FirstName, LastName, DepartmentID, Salary, JoinDate
        FROM Emp_Master
        WHERE ' + QUOTENAME(@FilterColumn) + ' = @Value';

    EXEC sp_executesql
        @SQL,
        N'@Value NVARCHAR(100)',
        @Value = @FilterValue;
END;
GO


EXEC sp_GetEmployeesDynamic 'DepartmentID', '3';
GO

EXEC sp_GetEmployeesDynamic 'FirstName', 'John';
GO

-- Exe-11: Error Handling in Stored Procedure
-- Goal: Update salary with TRY...CATCH and custom error message

CREATE PROCEDURE sp_UpdateSalaryWithErrorHandling
    @EmployeeID INT,
    @NewSalary DECIMAL(10,2)
AS
BEGIN
    BEGIN TRY
        
        IF NOT EXISTS (SELECT 1 FROM Emp_Master WHERE EmployeeID = @EmployeeID)
        BEGIN
            THROW 50001, 'Employee ID does not exist.', 1;
        END

    
        UPDATE Emp_Master
        SET Salary = @NewSalary
        WHERE EmployeeID = @EmployeeID;

        PRINT 'Salary updated successfully.';
    END TRY

    BEGIN CATCH
        
        SELECT 
            ERROR_NUMBER() AS ErrorNumber,
            ERROR_MESSAGE() AS ErrorMessage;
    END CATCH
END;
GO

EXEC sp_UpdateSalaryWithErrorHandling 3, 9000.00;
GO

EXEC sp_UpdateSalaryWithErrorHandling 999, 5000.00;
GO