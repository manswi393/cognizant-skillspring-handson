-- CREATE BatchInsertEmployees PROCEDURE
CREATE PROCEDURE BatchInsertEmployees
AS
BEGIN
    BEGIN TRY
        BEGIN TRANSACTION;

        INSERT INTO Employees VALUES (1,'A','B','a@x.com',2000,1);
        INSERT INTO Employees VALUES (2,'C','D','c@x.com',2500,1);
        INSERT INTO Employees VALUES (3,'E','F','e@x.com',3000,2);

        COMMIT TRANSACTION;
    END TRY

    BEGIN CATCH
        ROLLBACK TRANSACTION;

        INSERT INTO AuditLog (Action, ErrorMessage)
        VALUES ('Batch Insert Failed', ERROR_MESSAGE());
    END CATCH
END;
GO
